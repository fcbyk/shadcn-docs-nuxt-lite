{
  "name": "@fcbyk/shadcn-docs-nuxt-lite",
  "type": "module",
  "version": "2026.5.12",
  "packageManager": "pnpm@11.0.3",
  "description": "A lite version of shadcn-docs-nuxt focused on writing Markdown docs.",
  "license": "MIT",
  "main": "./nuxt.config.ts",
  "files": [
    "app",
    "app.vue",
    "assets",
    "components",
    "composables",
    "layouts",
    "lib",
    "nuxt.config.ts",
    "modules",
    "tailwind.config.js",
    "pages",
    "types"
  ],
  "scripts": {
    "pack:local": "mkdir -p dist && find dist -name '*.tgz' -delete && pnpm pack --pack-destination dist && mv dist/*.tgz dist/local-pkg.tgz",
    "build": "nuxt prepare && nuxt build www",
    "dev": "nuxt prepare && nuxt dev www",
    "generate": "nuxt prepare && nuxt generate www",
    "preview": "nuxt prepare && nuxt preview www",
    "typecheck": "nuxt prepare && nuxt typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.105",
    "@iconify-json/vscode-icons": "^1.2.47",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.1",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/mdc": "^0.21.1",
    "@tailwindcss/vite": "^4.2.4",
    "@ztl-uwu/nuxt-content": "^2.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "reka-ui": "^2.9.6",
    "shadcn-nuxt": "^2.6.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "ufo": "^1.6.4",
    "@nuxt/kit": "^4.4.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@iconify/utils": "^3.1.1",
    "@nuxt/devtools": "^3.2.4",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "eslint": "^10.2.1",
    "minisearch": "^7.2.0",
    "nuxt": "^4.4.4",
    "pkg-pr-new": "^0.0.68",
    "shiki": "^4.0.2",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "vue-tsc": "^3.2.7"
  }
}